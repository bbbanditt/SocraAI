const CARD_LABELS = {
  clarifying:  'Clarifying question',
  connection:  'Connection prompt',
  challenge:   'Challenge',
  reflection:  'Reflection',
};

const CARD_BADGE_COLORS = {
  clarifying:  '#0D9488',
  connection:  '#6366F1',
  challenge:   '#F43F5E',
  reflection:  '#8B5CF6',
};

let turnIndex = 0;
let hintCount = 0;
let hintsThisTurn = 0;
const HINTS = [
  [
    { level: 'Directional', text: "Think about what the sign of 'a' changes geometrically. If 'a' is positive, the arms go up. What would a negative 'a' do to those arms?" },
    { level: 'Structural',  text: "Imagine the parabola as a cup. When a > 0, it holds water. When a < 0, what happens to the cup's orientation?" },
    { level: 'Near answer', text: "The vertex stays determined by the formula. What changes is <em>which direction</em> it opens. Can you now state a rule about 'a' and direction?" },
  ],
  [
    { level: 'Directional', text: "Focus on the sign first, then the number. If −2x² opens down, what does the 2 change compared to −x²?" },
    { level: 'Structural',  text: "Larger |a| means the parabola is 'steeper' or 'narrower'. Smaller |a| means 'wider'. Does f(x) = −2x² look more stretched or compressed than f(x) = −x²?" },
    { level: 'Near answer', text: "f(x) = −2x²: opens downward (negative), steeper than f(x) = −x² (multiplier 2). Can you describe both properties now?" },
  ],
  [
    { level: 'Directional', text: "Start with: 'The sign of a tells you…' then: 'The size of a tells you…'" },
    { level: 'Structural',  text: "Think of 'a' as two separate controls: a switch (positive/negative) and a dial (how big). Describe each control." },
    { level: 'Near answer', text: "Sign → direction. Size → how narrow/wide. Positive a → cup shape. Negative a → dome shape. Now put this in one plain sentence." },
  ],
  [],
];

// Build step list
function buildSteps() {
  const list = document.getElementById('step-list');
  list.innerHTML = '';
  STEPS.forEach((step, i) => {
    const isLast = i === STEPS.length - 1;
    const wrapper = document.createElement('div');
    wrapper.style.cssText = 'display:flex; gap:9px; align-items:flex-start;';

    const col = document.createElement('div');
    col.style.cssText = 'display:flex; flex-direction:column; align-items:center;';

    const dot = document.createElement('div');
    dot.id = 'step-dot-' + i;
    dot.className = 'step-dot ' + (step.state === 'done' ? 'done' : step.state === 'current' ? 'current' : '');
    dot.style.marginTop = '2px';
    col.appendChild(dot);

    if (!isLast) {
      const line = document.createElement('div');
      line.id = 'step-line-' + i;
      line.className = 'step-line ' + (step.state === 'done' ? 'done' : '');
      col.appendChild(line);
    }

    const text = document.createElement('div');
    text.style.paddingBottom = isLast ? '0' : '16px';
    const label = document.createElement('div');
    label.id = 'step-label-' + i;
    label.style.cssText = 'font-size:12px; font-weight:500; color:' + (step.state === 'done' ? '#0D9488' : step.state === 'current' ? '#0F172A' : '#94A3B8') + ';';
    label.textContent = step.label;
    const sub = document.createElement('div');
    sub.id = 'step-sub-' + i;
    sub.style.cssText = 'font-size:10px; margin-top:1px; color:' + (step.state === 'done' ? '#94A3B8' : step.state === 'current' ? '#0D9488' : '#CBD5E1') + ';';
    sub.textContent = step.state === 'done' ? 'Demonstrated ✓' : step.state === 'current' ? 'Current step' : 'Upcoming';
    text.appendChild(label);
    text.appendChild(sub);

    wrapper.appendChild(col);
    wrapper.appendChild(text);
    list.appendChild(wrapper);
  });
}

// Render first question
function initConversation() {
  buildSteps();
  renderSocraCard(turnIndex);
  updateConfidence(64, 'Building');
}

function renderSocraCard(idx) {
  const turn = TURNS[idx];
  const feed = document.getElementById('conversation-feed');

  // Header label for this turn
  const header = document.createElement('div');
  header.style.cssText = 'display:flex; align-items:center; gap:8px; margin-bottom:14px;';
  header.innerHTML = `
    <span style="font-size:10px; font-weight:700; color:#94A3B8; text-transform:uppercase; letter-spacing:0.7px;">Guided Discovery</span>
    <span style="font-size:10px; background:#F0FDFA; color:#0D9488; padding:2px 8px; border-radius:20px; border:1px solid #99F6E4;">Step ${turnIndex + 3} of 5</span>
  `;
  feed.appendChild(header);

  // Socra question card
  const card = document.createElement('div');
  card.className = 'socra-bubble fade-up';
  card.style.marginBottom = '16px';
  card.innerHTML = `
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:6px;">
      <span style="font-size:10px; font-weight:700; color:${CARD_BADGE_COLORS[turn.type]}; text-transform:uppercase; letter-spacing:0.5px;">${CARD_LABELS[turn.type]}</span>
      <button onclick="toggleWhy(this)" style="font-size:11px; color:#64748B; background:none; border:none; cursor:pointer;">Why Socra asks ▾</button>
    </div>
    <p style="font-size:16px; font-weight:500; color:#0F172A; line-height:1.65; margin:0;">${turn.question}</p>
    <div class="why-block" style="display:none; margin-top:10px; padding:9px 12px; background:white; border-radius:7px; border:1px solid #99F6E4; font-size:12px; color:#0F172A; line-height:1.6;">${turn.why}</div>
  `;
  feed.appendChild(card);

  // Response area
  const responseBlock = document.createElement('div');
  responseBlock.id = 'response-block-' + idx;
  responseBlock.className = 'fade-up';
  responseBlock.style.marginBottom = '14px';
  responseBlock.innerHTML = `
    <div style="font-size:11px; font-weight:600; color:#475569; margin-bottom:8px;">Your thinking</div>
    <textarea class="response-input" id="ta-${idx}" placeholder="Type out your thinking — there's no wrong answer here, only clearer thinking…"></textarea>
    <div style="display:flex; gap:8px; margin-top:10px; flex-wrap:wrap; align-items:center;">
      <button class="btn-primary" onclick="submitTurn(${idx})">Send my thinking →</button>
      <button class="btn-ghost" onclick="showStuck(${idx})">I don't know where to start</button>
    </div>
  `;
  feed.appendChild(responseBlock);

  // Hint section
  const hints = HINTS[idx];
  if (hints && hints.length > 0) {
    const hintSection = document.createElement('div');
    hintSection.id = 'hint-section-' + idx;
    hintSection.style.marginBottom = '8px';
    hintSection.innerHTML = `
      <div style="border-top:1px solid #E2E8F0; padding-top:12px; display:flex; align-items:center; justify-content:space-between; margin-bottom:10px;">
        <span style="font-size:12px; color:#64748B;">Need a nudge?</span>
        <button class="btn-ghost" id="hint-btn-${idx}" onclick="revealHint(${idx})" style="padding:5px 12px; font-size:12px;">Show hint 1 of ${hints.length}</button>
      </div>
      <div id="hints-${idx}"></div>
    `;
    feed.appendChild(hintSection);
  }

  feed.scrollTop = feed.scrollHeight;
}

function toggleWhy(btn) {
  const block = btn.closest('.socra-bubble').querySelector('.why-block');
  block.style.display = block.style.display === 'none' ? 'block' : 'none';
}

let hintsRevealedPerTurn = {};

function revealHint(turnIdx) {
  if (!hintsRevealedPerTurn[turnIdx]) hintsRevealedPerTurn[turnIdx] = 0;
  const hints = HINTS[turnIdx];
  const already = hintsRevealedPerTurn[turnIdx];
  if (already >= hints.length) return;

  hintsRevealedPerTurn[turnIdx]++;
  hintCount++;

  const hint = hints[already];
  const container = document.getElementById('hints-' + turnIdx);
  const el = document.createElement('div');
  el.className = 'hint-bubble fade-up';
  el.style.marginBottom = '8px';
  el.innerHTML = `
    <div style="font-size:10px; font-weight:700; color:#B45309; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:5px;">Hint ${already + 1} — ${hint.level}</div>
    <p style="font-size:13px; color:#0F172A; line-height:1.6; margin:0;">${hint.text}</p>
  `;
  container.appendChild(el);

  // Update hint button
  const btn = document.getElementById('hint-btn-' + turnIdx);
  if (hintsRevealedPerTurn[turnIdx] >= hints.length) {
    btn.textContent = 'All hints shown';
    btn.disabled = true;
    btn.style.opacity = '0.5';
  } else {
    btn.textContent = `Show hint ${hintsRevealedPerTurn[turnIdx] + 1} of ${hints.length}`;
  }

  // Update hint dots
  if (hintCount <= 3) {
    document.getElementById('hdot-' + hintCount).classList.add('used');
    document.getElementById('hdot-label').textContent = hintCount + ' of 3';
  }

  document.getElementById('conversation-feed').scrollTop = 99999;
}

function showStuck(idx) {
  // Auto-reveal first hint
  revealHint(idx);
}

function submitTurn(idx) {
  const ta = document.getElementById('ta-' + idx);
  if (ta.value.trim().length < 8) {
    ta.style.borderColor = '#F43F5E';
    ta.placeholder = "Please share your thinking — even a rough idea helps Socra guide you.";
    setTimeout(() => { ta.style.borderColor = '#E2E8F0'; }, 1800);
    return;
  }

  // Lock this response
  const block = document.getElementById('response-block-' + idx);
  const submitted = ta.value.trim();
  block.innerHTML = `
    <div class="student-bubble fade-up" style="position:relative;">
      <div style="font-size:11px; font-weight:600; color:#475569; margin-bottom:5px;">Your response</div>
      <div style="font-size:14px; color:#0F172A; line-height:1.6;">${submitted.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>
    </div>
  `;

  const turn = TURNS[idx];

  // Advance step if needed
  if (turn.stepAdvance !== null) {
    const si = turn.stepAdvance;
    // Mark current as done
    const prevCurrent = STEPS.findIndex(s => s.state === 'current');
    if (prevCurrent >= 0) {
      STEPS[prevCurrent].state = 'done';
      const dot = document.getElementById('step-dot-' + prevCurrent);
      if (dot) { dot.className = 'step-dot done'; }
      const line = document.getElementById('step-line-' + prevCurrent);
      if (line) line.className = 'step-line done';
      const lbl = document.getElementById('step-label-' + prevCurrent);
      if (lbl) lbl.style.color = '#0D9488';
      const sub = document.getElementById('step-sub-' + prevCurrent);
      if (sub) { sub.textContent = 'Demonstrated ✓'; sub.style.color = '#94A3B8'; }
    }
    // Mark next as current
    if (si < STEPS.length) {
      STEPS[si].state = 'current';
      const dot = document.getElementById('step-dot-' + si);
      if (dot) { dot.className = 'step-dot current'; }
      const lbl = document.getElementById('step-label-' + si);
      if (lbl) lbl.style.color = '#0F172A';
      const sub = document.getElementById('step-sub-' + si);
      if (sub) { sub.textContent = 'Current step'; sub.style.color = '#0D9488'; }
    }
  }

  // Add confirmed knowledge tag
  if (turn.newTag) {
    const tags = document.getElementById('knowledge-tags');
    const t = document.createElement('span');
    t.className = 'knowledge-tag fade-up';
    t.textContent = turn.newTag;
    tags.appendChild(t);
  }

  // Update hypothesis
  const hypoMap = [
    null,
    `"When a is negative the parabola opens downward — the opposite direction from when a is positive."`,
    `"Sign of a → direction. Size of a → how steep/wide the parabola is."`,
    `"The sign of a is like a switch: positive = cup shape, negative = dome shape. The size of a controls the steepness."`,
  ];
  if (hypoMap[idx + 1]) {
    document.getElementById('hypothesis-text').innerHTML = hypoMap[idx + 1];
    document.getElementById('hypothesis-time').textContent = 'Just updated';
  }

  // Update confidence
  updateConfidence(turn.confAfter, turn.confLabel);

  // Next turn
  turnIndex = idx + 1;
  const feed = document.getElementById('conversation-feed');

  if (turnIndex < TURNS.length) {
    // Small pause then show next question
    setTimeout(() => {
      const sep = document.createElement('div');
      sep.style.cssText = 'border-top:1px solid #E2E8F0; margin:20px 0;';
      feed.appendChild(sep);
      renderSocraCard(turnIndex);
    }, 600);
  } else {
    // Session complete
    setTimeout(() => {
      const complete = document.createElement('div');
      complete.className = 'fade-up';
      complete.style.cssText = 'text-align:center; padding:32px 20px;';
      complete.innerHTML = `
        <div style="width:56px; height:56px; background:#F0FDFA; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 14px; border:2px solid #0D9488;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L20 7" stroke="#0D9488" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div style="font-size:18px; font-weight:700; color:#0F172A; margin-bottom:6px;">Session complete</div>
        <div style="font-size:14px; color:#64748B; margin-bottom:20px;">You demonstrated reasoning across all 5 steps. Confidence: <strong style="color:#0D9488;">92%</strong></div>
        <button class="btn-primary" onclick="goTo('progress')" style="margin:0 auto;">View my progress →</button>
      `;
      feed.appendChild(complete);
      feed.scrollTop = feed.scrollHeight;

      // Mark all steps done
      STEPS.forEach((s, i) => {
        s.state = 'done';
        const dot = document.getElementById('step-dot-' + i);
        if (dot) dot.className = 'step-dot done';
        const line = document.getElementById('step-line-' + i);
        if (line) line.className = 'step-line done';
        const lbl = document.getElementById('step-label-' + i);
        if (lbl) lbl.style.color = '#0D9488';
        const sub = document.getElementById('step-sub-' + i);
        if (sub) { sub.textContent = 'Demonstrated ✓'; sub.style.color = '#94A3B8'; }
      });
      updateConfidence(92, 'Near mastery');
    }, 600);
  }
}

function updateConfidence(pct, label) {
  document.getElementById('conf-pct').textContent = pct + '%';
  document.getElementById('conf-label').textContent = label;
  document.getElementById('conf-bar').style.width = pct + '%';
  // SVG ring: circumference = 2π×24 ≈ 151, offset = 151 × (1 - pct/100)
  const offset = Math.round(151 * (1 - pct / 100));
  document.getElementById('conf-ring').setAttribute('stroke-dashoffset', offset);
}

// Hypothesis revise button
function reviseHypothesis() {
  const box = document.getElementById('hypothesis-box');
  const current = document.getElementById('hypothesis-text').textContent.replace(/"/g,'');
  box.innerHTML = `
    <textarea style="width:100%; border:none; outline:none; font-size:12px; color:#0F172A; line-height:1.5; resize:none; background:transparent; font-family:Inter,sans-serif;" rows="3" id="hypo-edit">${current}</textarea>
    <div style="display:flex; gap:6px; margin-top:6px;">
      <button class="btn-primary" style="padding:4px 10px; font-size:11px;" onclick="saveHypothesis()">Save</button>
      <button class="btn-ghost" style="padding:4px 10px; font-size:11px;" onclick="cancelHypothesis('${current.replace(/'/g,"\\'")}')">Cancel</button>
    </div>
  `;
}
function saveHypothesis() {
  const val = document.getElementById('hypo-edit').value.trim();
  document.getElementById('hypothesis-box').innerHTML = `
    <div style="font-size:12px; color:#0F172A; line-height:1.5;" id="hypothesis-text">"${val}"</div>
    <div style="font-size:10px; color:#94A3B8; margin-top:5px;" id="hypothesis-time">Just updated</div>
  `;
}
function cancelHypothesis(old) {
  document.getElementById('hypothesis-box').innerHTML = `
    <div style="font-size:12px; color:#0F172A; line-height:1.5;" id="hypothesis-text">"${old}"</div>
    <div style="font-size:10px; color:#94A3B8; margin-top:5px;" id="hypothesis-time">Updated 3 min ago</div>
  `;
}

// ─────────────────────────────────────────────────
// HEATMAP
// ─────────────────────────────────────────────────
const topics = ['Cell Division','Photosynthesis','ATP Synthesis','DNA Replication','Mitosis vs Meiosis'];
const students = ['Aida','Ben','Cara','Dan','Eva','Finn','Gina','Hana','Ivan','Jake','Kim','Leo','Mia','Noa','Omar'];
const heatColors = {
  mastered:'#10B981', building:'#34D399', developing:'#F59E0B',
  struggling:'#FB923C', misconception:'#F43F5E', notstarted:'#E2E8F0'
};
const heatData = [
  ['mastered','mastered','building','developing','misconception','struggling','mastered','building','notstarted','misconception','developing','mastered','building','mastered','struggling'],
  ['misconception','developing','struggling','mastered','developing','building','misconception','misconception','struggling','developing','mastered','developing','misconception','building','notstarted'],
  ['developing','building','developing','developing','struggling','misconception','developing','notstarted','developing','struggling','developing','building','developing','developing','developing'],
  ['mastered','mastered','mastered','building','mastered','building','developing','mastered','mastered','building','mastered','mastered','mastered','building','developing'],
  ['building','developing','misconception','building','building','developing','building','developing','developing','misconception','building','building','developing','building','struggling'],
];

function buildHeatmap() {
  const container = document.getElementById('heatmap-container');
  if (!container) return;
  const table = document.createElement('table');
  table.style.cssText = 'border-collapse:separate; border-spacing:4px; min-width:500px;';

  // Header row
  const thead = document.createElement('thead');
  const hrow = document.createElement('tr');
  const empty = document.createElement('td');
  empty.style.width = '140px';
  hrow.appendChild(empty);
  students.forEach(s => {
    const th = document.createElement('td');
    th.style.cssText = 'font-size:10px; color:#94A3B8; text-align:center; font-weight:500; padding:0 1px;';
    th.textContent = s.slice(0,3);
    hrow.appendChild(th);
  });
  thead.appendChild(hrow);
  table.appendChild(thead);

  // Data rows
  const tbody = document.createElement('tbody');
  topics.forEach((topic, ti) => {
    const tr = document.createElement('tr');
    const tdl = document.createElement('td');
    tdl.style.cssText = 'font-size:12px; color:#475569; font-weight:500; padding-right:8px; white-space:nowrap;';
    tdl.textContent = topic;
    tr.appendChild(tdl);
    heatData[ti].forEach((state, si) => {
      const td = document.createElement('td');
      const cell = document.createElement('div');
      cell.className = 'heatmap-cell';
      cell.style.background = heatColors[state];
      cell.title = `${students[si]} · ${topic}: ${state.replace('notstarted','not started')}`;
      cell.onclick = () => openDrawer();
      td.appendChild(cell);
      tr.appendChild(td);
    });
    tbody.appendChild(tr);
  });
  table.appendChild(tbody);
  container.appendChild(table);
}

// ─────────────────────────────────────────────────
// DRAWER
// ─────────────────────────────────────────────────
function openDrawer() {
  document.getElementById('student-drawer').classList.add('open');
  document.getElementById('overlay').classList.add('open');
}
function closeDrawer() {
  document.getElementById('student-drawer').classList.remove('open');
  document.getElementById('overlay').classList.remove('open');
}

// ─────────────────────────────────────────────────
// INIT
// ─────────────────────────────────────────────────
initConversation();
buildHeatmap();
</script>
